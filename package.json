{
  "name": "didcomm-http",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "openapi:export": "node --import tsx scripts/export-openapi.ts",
    "docker:build": "docker build -t onyxblade/didcomm-http .",
    "docker:push": "docker build -t onyxblade/didcomm-http:latest -t onyxblade/didcomm-http:$(git rev-parse --short HEAD) . && docker push onyxblade/didcomm-http:latest && docker push onyxblade/didcomm-http:$(git rev-parse --short HEAD)"
  },
  "author": "merely",
  "license": "Apache-2.0",
  "description": "DIDComm HTTP server wrapping didcomm-rust WASM and DID resolvers",
  "dependencies": {
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sinclair/typebox": "^0.34.14",
    "did-resolver": "^4.1.0",
    "didcomm-node": "^0.4.1",
    "didwebvh-ts": "^2.7.1",
    "fastify": "^5.2.1",
    "web-did-resolver": "^2.0.27"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
